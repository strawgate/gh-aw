#!/usr/bin/env bash
# Launcher for the Pydantic AI harness.
#
# gh-aw runs the engine command inside the AWF firewall sandbox, where PATH is
# rebuilt by scanning only for directories literally named "bin" under the
# tool cache. astral-sh/setup-uv does not always install uv into such a
# directory, so the harness script's `#!/usr/bin/env -S uv run --script`
# shebang can fail with "env: 'uv': No such file or directory" before any
# output is produced (surfaces as "no structured log entries").
#
# This launcher is committed in the repo (checked out by gh-aw like the
# harness itself), locates uv robustly, and emits loud diagnostics to stderr
# (captured in agent-stdio.log) so any remaining startup failure is visible.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runner="${here}/pydantic-ai-runner"

echo "[harness-launch] cwd=$(pwd) here=${here}" >&2
echo "[harness-launch] runner=${runner} exists=$([ -f "${runner}" ] && echo yes || echo no)" >&2
echo "[harness-launch] PATH=${PATH}" >&2

uv_bin=""
if command -v uv >/dev/null 2>&1; then
  uv_bin="$(command -v uv)"
else
  for cand in \
    "${HOME}/.local/bin/uv" \
    "${RUNNER_TOOL_CACHE:-/opt/hostedtoolcache}"/uv/*/*/uv \
    /opt/hostedtoolcache/uv/*/*/uv \
    /home/runner/work/_tool/uv/*/*/uv \
    /usr/local/bin/uv; do
    if [ -x "${cand}" ]; then
      uv_bin="${cand}"
      break
    fi
  done
fi

if [ -z "${uv_bin}" ]; then
  echo "[harness-launch] FATAL: uv not found on PATH or known locations" >&2
  echo "[harness-launch] HOME=${HOME} RUNNER_TOOL_CACHE=${RUNNER_TOOL_CACHE:-unset}" >&2
  ls -la "${HOME}/.local/bin" 2>&1 | sed 's/^/[harness-launch] ~\/.local\/bin: /' >&2 || true
  exit 127
fi

echo "[harness-launch] using uv=${uv_bin} ($("${uv_bin}" --version 2>&1 || true))" >&2
exec "${uv_bin}" run --script "${runner}" "$@"
